  <preferences>
    <color-palette name="Health Status Colors" type="regular">
      <color>#22b14c</color>
      <color>#ff7f27</color>
      <color>#ed1c24</color>
    </color-palette>
  </preferences>
  <datasources>
  <datasource caption="Billing Feed Data" inline="true" name="billing_feed_data" version="18.1">
    <connection class="federated">
      <named-connections>
        <named-connection caption="billing_feed_data_advanced" name="textscan.0">
          <connection class="textscan" directory="Data" filename="billing_feed_data_advanced.csv" separator="," />
        </named-connection>
      </named-connections>
      <relation connection="textscan.0" name="billing_feed_data_advanced.csv" table="[billing_feed_data_advanced#csv]" type="table">
        <columns header="yes">
          <column datatype="integer" name="feed_id" ordinal="0" />
          <column datatype="date" name="billing_date" ordinal="1" />
          <column datatype="integer" name="source_count" ordinal="2" />
          <column datatype="integer" name="target_count" ordinal="3" />
          <column datatype="integer" name="file_count" ordinal="4" />
          <column datatype="datetime" name="ingestion_time" ordinal="5" />
          <column datatype="integer" name="processing_delay_min" ordinal="6" />
          <column datatype="datetime" name="update_dt" ordinal="7" />
          <column datatype="string" name="sla_breach" ordinal="8" />
          <column datatype="integer" name="version" ordinal="9" />
          <column datatype="string" name="version_type" ordinal="10" />
          <column datatype="string" name="version_status" ordinal="11" />
          <column datatype="string" name="feed_file_prefix" ordinal="12" />
        </columns>
      </relation>
      <metadata-records>
        <metadata-record class="column">
          <remote-name>feed_id</remote-name>
          <remote-type>20</remote-type>
          <local-name>[feed_id]</local-name>
          <parent-name>[billing_feed_data_advanced.csv]</parent-name>
          <remote-alias>feed_id</remote-alias>
          <ordinal>0</ordinal>
          <local-type>integer</local-type>
          <aggregation>Sum</aggregation>
          <contains-null>true</contains-null>
        </metadata-record>
        <metadata-record class="column">
          <remote-name>billing_date</remote-name>
          <remote-type>7</remote-type>
          <local-name>[billing_date]</local-name>
          <parent-name>[billing_feed_data_advanced.csv]</parent-name>
          <remote-alias>billing_date</remote-alias>
          <ordinal>1</ordinal>
          <local-type>date</local-type>
          <aggregation>Year</aggregation>
          <contains-null>true</contains-null>
        </metadata-record>
        <metadata-record class="column">
          <remote-name>source_count</remote-name>
          <remote-type>20</remote-type>
          <local-name>[source_count]</local-name>
          <parent-name>[billing_feed_data_advanced.csv]</parent-name>
          <remote-alias>source_count</remote-alias>
          <ordinal>2</ordinal>
          <local-type>integer</local-type>
