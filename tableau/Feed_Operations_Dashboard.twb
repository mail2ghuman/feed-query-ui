          <contains-null>true</contains-null>
        </metadata-record>
        <metadata-record class="column">
          <remote-name>target_count</remote-name>
          <remote-type>20</remote-type>
          <local-name>[target_count]</local-name>
          <parent-name>[billing_feed_data_advanced.csv]</parent-name>
          <remote-alias>target_count</remote-alias>
          <ordinal>3</ordinal>
          <local-type>integer</local-type>
          <aggregation>Sum</aggregation>
          <contains-null>true</contains-null>
        </metadata-record>
        <metadata-record class="column">
          <remote-name>file_count</remote-name>
          <remote-type>20</remote-type>
          <local-name>[file_count]</local-name>
          <parent-name>[billing_feed_data_advanced.csv]</parent-name>
          <remote-alias>file_count</remote-alias>
          <ordinal>4</ordinal>
          <local-type>integer</local-type>
          <aggregation>Sum</aggregation>
          <contains-null>true</contains-null>
        </metadata-record>
        <metadata-record class="column">
          <remote-name>ingestion_time</remote-name>
