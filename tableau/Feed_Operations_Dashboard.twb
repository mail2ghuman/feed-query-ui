          </column>
          <column datatype="integer" name="[Calculation_SourceTargetDiff]" role="measure" type="quantitative">
            <calculation class="tableau" formula="[source_count] - [target_count]" />
          </column>
          <column datatype="real" name="[Calculation_DiscrepancyPct]" role="measure" type="quantitative">
            <calculation class="tableau" formula="IF [source_count] = 0 THEN 0
ELSE ABS([source_count] - [target_count]) / [source_count]
END" />
          </column>
          <column datatype="string" name="[Calculation_HasRetries]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [version] &gt; 1 THEN &quot;Yes&quot; ELSE &quot;No&quot; END" />
          </column>
          <column datatype="string" name="[Calculation_DelayBucket]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [processing_delay_min] &lt;= 60 THEN &quot;0-60 min&quot;
ELSEIF [processing_delay_min] &lt;= 120 THEN &quot;60-120 min&quot;
ELSEIF [processing_delay_min] &lt;= 180 THEN &quot;120-180 min&quot;
ELSEIF [processing_delay_min] &lt;= 300 THEN &quot;180-300 min&quot;
ELSE &quot;300+ min (Critical)&quot;
END" />
          </column>
          <column datatype="string" name="[Calculation_HealthColor]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [sla_breach] = &quot;True&quot; THEN &quot;red&quot;
ELSEIF [processing_delay_min] &gt; 300 THEN &quot;amber&quot;
ELSE &quot;green&quot;
END" />
          </column>
          <column datatype="real" name="[Calculation_FeedHealth]" role="measure" type="quantitative">
            <calculation class="tableau" formula="SUM(IF [sla_breach] = &quot;False&quot; AND [processing_delay_min] &lt;= 300 THEN 1 ELSE 0 END) / COUNT([feed_id]) * 100" />
          </column>
          <column-instance column="[Calculation_FeedHealth]" derivation="Avg" name="[avg:Calculation_FeedHealth:qk]" pivot="key" type="quantitative" />
          <column-instance column="[feed_id]" derivation="Count" name="[cnt:feed_id:qk]" pivot="key" type="nominal" />
          <column-instance column="[processing_delay_min]" derivation="Avg" name="[avg:processing_delay_min:qk]" pivot="key" type="quantitative" />
          <column-instance column="[source_count]" derivation="Sum" name="[sum:source_count:qk]" pivot="key" type="quantitative" />
          <column-instance column="[target_count]" derivation="Sum" name="[sum:target_count:qk]" pivot="key" type="quantitative" />
        </datasource-dependencies>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option="selection-relaxation-allow">
          <view>
            <breakdown value="auto" />
          </view>
          <mark class="Text" />
          <encodings>
            <text column="[billing_feed_data].[avg:Calculation_FeedHealth:qk]" />
            <tooltip column="[billing_feed_data].[sum:source_count:qk]" />
            <tooltip column="[billing_feed_data].[sum:target_count:qk]" />
            <tooltip column="[billing_feed_data].[avg:processing_delay_min:qk]" />
            <tooltip column="[billing_feed_data].[cnt:feed_id:qk]" />
          </encodings>
        </pane>
      </panes>
      <rows></rows>
      <cols>[billing_feed_data].[avg:Calculation_FeedHealth:qk]</cols>
    </table>
  </worksheet>
