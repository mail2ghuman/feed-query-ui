          <column datatype="datetime" name="[update_dt]" role="dimension" type="ordinal" />
          <column datatype="string" name="[sla_breach]" role="dimension" type="nominal" />
          <column datatype="integer" name="[version]" role="measure" type="quantitative" />
          <column datatype="string" name="[version_type]" role="dimension" type="nominal" />
          <column datatype="string" name="[version_status]" role="dimension" type="nominal" />
          <column datatype="string" name="[feed_file_prefix]" role="dimension" type="nominal" />
          <column datatype="string" name="[Calculation_HealthStatus]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [sla_breach] = &quot;True&quot; THEN &quot;Failed&quot;
ELSEIF [processing_delay_min] &gt; 300 THEN &quot;Partial&quot;
ELSE &quot;Healthy&quot;
END" />
          </column>
          <column datatype="string" name="[Calculation_Country]" role="dimension" type="nominal">
