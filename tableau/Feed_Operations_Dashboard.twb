<?xml version="1.0" encoding="utf-8"?>
<workbook original-version="26.1" source-build="0.0.0 (0000.0.0.0)" source-platform="win" version="26.1" xmlns:user="http://www.tableausoftware.com/xml/user">
  <document-format-change-manifest>
    <ManifestByVersion />
  </document-format-change-manifest>
  <preferences>
    <color-palette name="Health Status Colors" type="regular">
      <color>#22b14c</color>
      <color>#ff7f27</color>
      <color>#ed1c24</color>
    </color-palette>
  </preferences>
  <datasources>
  <datasource caption="Billing Feed Data" inline="true" name="billing_feed_data" version="26.1">
    <connection class="textscan" directory="Data" filename="billing_feed_data_advanced.csv" separator=",">
      <relation name="billing_feed_data_advanced.csv" table="[billing_feed_data_advanced#csv]" type="table">
        <columns header="yes">
          <column datatype="integer" name="feed_id" ordinal="0" />
          <column datatype="date" name="billing_date" ordinal="1" />
          <column datatype="integer" name="source_count" ordinal="2" />
          <column datatype="integer" name="target_count" ordinal="3" />
          <column datatype="integer" name="file_count" ordinal="4" />
          <column datatype="datetime" name="ingestion_time" ordinal="5" />
          <column datatype="integer" name="processing_delay_min" ordinal="6" />
          <column datatype="datetime" name="update_dt" ordinal="7" />
          <column datatype="string" name="sla_breach" ordinal="8" />
          <column datatype="integer" name="version" ordinal="9" />
          <column datatype="string" name="version_type" ordinal="10" />
          <column datatype="string" name="version_status" ordinal="11" />
          <column datatype="string" name="feed_file_prefix" ordinal="12" />
        </columns>
      </relation>
    </connection>
    <column caption="Feed ID" datatype="integer" name="[feed_id]" role="dimension" type="nominal" />
    <column caption="Billing Date" datatype="date" name="[billing_date]" role="dimension" type="ordinal" />
    <column caption="Source Count" datatype="integer" name="[source_count]" role="measure" type="quantitative" />
    <column caption="Target Count" datatype="integer" name="[target_count]" role="measure" type="quantitative" />
    <column caption="File Count" datatype="integer" name="[file_count]" role="measure" type="quantitative" />
    <column caption="Ingestion Time" datatype="datetime" name="[ingestion_time]" role="dimension" type="ordinal" />
    <column caption="Processing Delay (min)" datatype="integer" name="[processing_delay_min]" role="measure" type="quantitative" />
    <column caption="Update Timestamp" datatype="datetime" name="[update_dt]" role="dimension" type="ordinal" />
    <column caption="SLA Breach" datatype="string" name="[sla_breach]" role="dimension" type="nominal" />
    <column caption="Version" datatype="integer" name="[version]" role="measure" type="quantitative" />
    <column caption="Version Type" datatype="string" name="[version_type]" role="dimension" type="nominal" />
    <column caption="Version Status" datatype="string" name="[version_status]" role="dimension" type="nominal" />
    <column caption="Feed File Prefix" datatype="string" name="[feed_file_prefix]" role="dimension" type="nominal" />
    <column caption="Health Status" datatype="string" name="[Calculation_HealthStatus]" role="dimension" type="nominal">
      <calculation class="tableau" formula="IF [sla_breach] = &quot;True&quot; THEN &quot;Failed&quot;
ELSEIF [processing_delay_min] &gt; 300 THEN &quot;Partial&quot;
ELSE &quot;Healthy&quot;
END" />
    </column>
    <column caption="Country" datatype="string" name="[Calculation_Country]" role="dimension" type="nominal">
      <calculation class="tableau" formula="RIGHT([feed_file_prefix], 2)" />
    </column>
    <column caption="Source Target Diff" datatype="integer" name="[Calculation_SourceTargetDiff]" role="measure" type="quantitative">
      <calculation class="tableau" formula="[source_count] - [target_count]" />
    </column>
    <column caption="Discrepancy %" datatype="real" name="[Calculation_DiscrepancyPct]" role="measure" type="quantitative">
      <calculation class="tableau" formula="IF [source_count] = 0 THEN 0
ELSE ABS([source_count] - [target_count]) / [source_count]
END" />
    </column>
    <column caption="Has Retries" datatype="string" name="[Calculation_HasRetries]" role="dimension" type="nominal">
      <calculation class="tableau" formula="IF [version] &gt; 1 THEN &quot;Yes&quot; ELSE &quot;No&quot; END" />
    </column>
    <column caption="Delay Bucket" datatype="string" name="[Calculation_DelayBucket]" role="dimension" type="nominal">
      <calculation class="tableau" formula="IF [processing_delay_min] &lt;= 60 THEN &quot;0-60 min&quot;
ELSEIF [processing_delay_min] &lt;= 120 THEN &quot;60-120 min&quot;
ELSEIF [processing_delay_min] &lt;= 180 THEN &quot;120-180 min&quot;
ELSEIF [processing_delay_min] &lt;= 300 THEN &quot;180-300 min&quot;
ELSE &quot;300+ min (Critical)&quot;
END" />
    </column>
    <column caption="Health Color" datatype="string" name="[Calculation_HealthColor]" role="dimension" type="nominal">
      <calculation class="tableau" formula="IF [sla_breach] = &quot;True&quot; THEN &quot;red&quot;
ELSEIF [processing_delay_min] &gt; 300 THEN &quot;amber&quot;
ELSE &quot;green&quot;
END" />
    </column>
    <column caption="Feed Health Score" datatype="real" name="[Calculation_FeedHealth]" role="measure" type="quantitative">
      <calculation class="tableau" formula="SUM(IF [sla_breach] = &quot;False&quot; AND [processing_delay_min] &lt;= 300 THEN 1 ELSE 0 END) / COUNT([feed_id]) * 100" />
    </column>
  </datasource>
  </datasources>
  <worksheets>
