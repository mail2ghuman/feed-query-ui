          </column>
        </datasource-dependencies>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane>
          <view>
            <breakdown value="auto" />
          </view>
          <mark class="Text" type="Text" />
        </pane>
      </panes>
      <rows></rows>
      <cols>[billing_feed_data].[sum:source_count:qk] [billing_feed_data].[sum:target_count:qk] [billing_feed_data].[avg:processing_delay_min:qk]</cols>
    </table>
    <simple-id uuid="{7946b43c-f6f2-4278-b208-27cbdd99b150}" />
