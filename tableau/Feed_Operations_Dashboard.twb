  <worksheet name="SLA Breach Heatmap" number="5">
    <table>
      <view>
        <datasources>
          <datasource caption="Billing Feed Data" name="billing_feed_data" />
        </datasources>
        <datasource-dependencies datasource="billing_feed_data">
          <column datatype="integer" name="[feed_id]" role="dimension" type="nominal" />
          <column datatype="date" name="[billing_date]" role="dimension" type="ordinal" />
          <column datatype="integer" name="[source_count]" role="measure" type="quantitative" />
          <column datatype="integer" name="[target_count]" role="measure" type="quantitative" />
          <column datatype="integer" name="[file_count]" role="measure" type="quantitative" />
          <column datatype="datetime" name="[ingestion_time]" role="dimension" type="ordinal" />
          <column datatype="integer" name="[processing_delay_min]" role="measure" type="quantitative" />
          <column datatype="datetime" name="[update_dt]" role="dimension" type="ordinal" />
          <column datatype="string" name="[sla_breach]" role="dimension" type="nominal" />
          <column datatype="integer" name="[version]" role="measure" type="quantitative" />
          <column datatype="string" name="[version_type]" role="dimension" type="nominal" />
          <column datatype="string" name="[version_status]" role="dimension" type="nominal" />
          <column datatype="string" name="[feed_file_prefix]" role="dimension" type="nominal" />
          <column datatype="string" name="[Calculation_HealthStatus]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [sla_breach] = &quot;True&quot; THEN &quot;Failed&quot;
ELSEIF [processing_delay_min] &gt; 300 THEN &quot;Partial&quot;
ELSE &quot;Healthy&quot;
END" />
          </column>
          <column datatype="string" name="[Calculation_Country]" role="dimension" type="nominal">
            <calculation class="tableau" formula="RIGHT([feed_file_prefix], 2)" />
          </column>
          <column datatype="integer" name="[Calculation_SourceTargetDiff]" role="measure" type="quantitative">
            <calculation class="tableau" formula="[source_count] - [target_count]" />
          </column>
          <column datatype="real" name="[Calculation_DiscrepancyPct]" role="measure" type="quantitative">
            <calculation class="tableau" formula="IF [source_count] = 0 THEN 0
ELSE ABS([source_count] - [target_count]) / [source_count]
END" />
          </column>
          <column datatype="string" name="[Calculation_HasRetries]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [version] &gt; 1 THEN &quot;Yes&quot; ELSE &quot;No&quot; END" />
          </column>
          <column datatype="string" name="[Calculation_DelayBucket]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [processing_delay_min] &lt;= 60 THEN &quot;0-60 min&quot;
ELSEIF [processing_delay_min] &lt;= 120 THEN &quot;60-120 min&quot;
ELSEIF [processing_delay_min] &lt;= 180 THEN &quot;120-180 min&quot;
ELSEIF [processing_delay_min] &lt;= 300 THEN &quot;180-300 min&quot;
ELSE &quot;300+ min (Critical)&quot;
END" />
          </column>
          <column datatype="string" name="[Calculation_HealthColor]" role="dimension" type="nominal">
            <calculation class="tableau" formula="IF [sla_breach] = &quot;True&quot; THEN &quot;red&quot;
ELSEIF [processing_delay_min] &gt; 300 THEN &quot;amber&quot;
ELSE &quot;green&quot;
END" />
          </column>
          <column datatype="real" name="[Calculation_FeedHealth]" role="measure" type="quantitative">
            <calculation class="tableau" formula="SUM(IF [sla_breach] = &quot;False&quot; AND [processing_delay_min] &lt;= 300 THEN 1 ELSE 0 END) / COUNT([feed_id]) * 100" />
          </column>
        </datasource-dependencies>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane>
          <view>
            <breakdown value="auto" />
          </view>
          <mark class="Square" type="Square" />
          <encodings>
            <color column="[billing_feed_data].[avg:processing_delay_min:qk]" />
            <tooltip column="[billing_feed_data].[none:Calculation_Country:nk]" />
            <tooltip column="[billing_feed_data].[none:billing_date:ok]" />
            <tooltip column="[billing_feed_data].[avg:processing_delay_min:qk]" />
            <tooltip column="[billing_feed_data].[sum:source_count:qk]" />
            <tooltip column="[billing_feed_data].[sum:target_count:qk]" />
          </encodings>
        </pane>
      </panes>
      <rows>[billing_feed_data].[none:Calculation_Country:nk]</rows>
      <cols>[billing_feed_data].[none:billing_date:ok]</cols>
    </table>
    <simple-id uuid="{8fdf94c1-5485-4bf0-b1b6-177f561a1b81}" />
    <worksheet-number number="5" />
  </worksheet>
