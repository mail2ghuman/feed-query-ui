          <local-type>string</local-type>
          <aggregation>Count</aggregation>
          <contains-null>true</contains-null>
        </metadata-record>
        <metadata-record class="column">
          <remote-name>version_status</remote-name>
          <remote-type>130</remote-type>
          <local-name>[version_status]</local-name>
          <parent-name>[billing_feed_data_advanced.csv]</parent-name>
          <remote-alias>version_status</remote-alias>
          <ordinal>11</ordinal>
          <local-type>string</local-type>
          <aggregation>Count</aggregation>
